{
  "$schema": "https://www.jamdesk.com/docs.json",
  "theme": "pulsar",
  "name": "Trillet AI",
  "colors": {
    "primary": "#0062E9",
    "light": "#27A3FD",
    "dark": "#0062E9"
  },
  "favicon": "favicon.svg",
  "logo": {
    "light": "/public/logo/Trillet-logo-light.png",
    "dark": "/public/logo/Trillet-logo-dark.svg",
    "href": "https://docs.trillet.ai/"
  },
  "api": {
    "mdx": {
      "server": "https://api.trillet.ai",
      "auth": {
        "method": "key",
        "name": "x-api-key"
      }
    }
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "background": {
    "decoration": "windows",
    "color": {
      "light": "#f5f8ff",
      "dark": "#000718"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Join Community",
        "href": "https://discord.com/invite/4qbWtkbT93"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started!",
      "href": "https://app.trillet.ai"
    }
  },
  "search": {
    "prompt": "Expedite Development - Search Trillet..."
  },
  "seo": {
    "indexing": "all"
  },
  "footer": {
    "socials": {
      "discord": "https://discord.com/invite/4qbWtkbT93",
      "github": "https://github.com/TrilletAI",
      "linkedin": "https://linkedin.com/company/trillet-ai"
